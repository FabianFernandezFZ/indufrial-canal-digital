          <div class="text-[10px] uppercase tracking-[0.26em] text-brand-700 font-extrabold mb-3">Valor</div>
          <div class="flex flex-wrap gap-2">
            <span class="mini-pill px-3 py-2 rounded-full text-xs font-bold">Problema</span>
            <span class="mini-pill px-3 py-2 rounded-full text-xs font-bold">Ahora</span>
            <span class="mini-pill px-3 py-2 rounded-full text-xs font-bold">Riesgo</span>
          </div>
        </div>
        <div class="card rounded-3xl p-4">
          <div class="text-[10px] uppercase tracking-[0.26em] text-brand-700 font-extrabold mb-3">Alcance</div>
