<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Indufrial | Resumen visual del alcance</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">

  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
          },
          colors: {
            brand: {
              50: '#f5f9ff',
              100: '#eaf3ff',
              200: '#d8e8ff',
              300: '#b9d5ff',
              400: '#7fb1ff',
              500: '#4f8df7',
              600: '#2563eb',
              700: '#1d4ed8',
              800: '#173ea8',
              900: '#0f2d74',
            }
          },
          boxShadow: {
            soft: '0 10px 30px rgba(15,23,42,0.06)',
            hover: '0 18px 40px rgba(37,99,235,0.10)',
          },
          borderRadius: {
            '4xl': '2rem'
          }
        }
      }
    }
  </script>

  <style>
    html { scroll-behavior: smooth; }
    body{
      font-family: 'Inter', sans-serif;
      background:
        radial-gradient(circle at top left, rgba(79,141,247,.08), transparent 24%),
        linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
      color:#0f172a;
      overflow-x:hidden;
    }

    .card{
      background: rgba(255,255,255,.92);
      border: 1px solid rgba(148,163,184,.18);
      box-shadow: 0 10px 30px rgba(15,23,42,.05);
      backdrop-filter: blur(10px);
      transition: all .25s ease;
    }

    .card:hover{
      transform: translateY(-2px);
      box-shadow: 0 18px 40px rgba(37,99,235,.10);
      border-color: rgba(37,99,235,.22);
    }

    .node-btn{
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(circle at top right, rgba(79,141,247,.10), transparent 28%),
        linear-gradient(180deg, #ffffff 0%, #f9fbff 100%);
      border:1px solid rgba(148,163,184,.18);
      box-shadow: 0 10px 30px rgba(15,23,42,.05);
      transition: all .22s ease;
    }

    .node-btn:hover,
    .node-btn.active{
      transform: translateY(-2px);
      border-color: rgba(37,99,235,.28);
      box-shadow: 0 18px 40px rgba(37,99,235,.10);
    }

    .flow-line{
      position:absolute;
      inset:0;
      pointer-events:none;
      opacity:.28;
    }
  </style>
</head>

<body class="p-4 md:p-6">

<section class="flow-shell card rounded-4xl p-4 md:p-6">

<!-- SVG CORREGIDO -->
<svg class="flow-line" viewBox="0 0 1200 760" preserveAspectRatio="none">

  <path d="M190 92 C 285 92, 285 92, 380 92" stroke="#2563eb" stroke-width="3" fill="none"/>
  <path d="M590 92 C 685 92, 685 92, 780 92" stroke="#2563eb" stroke-width="3" fill="none"/>

  <path d="M980 146 C 980 204, 980 204, 980 258" stroke="#2563eb" stroke-width="3" fill="none"/>

  <path d="M780 312 C 685 312, 685 312, 590 312" stroke="#2563eb" stroke-width="3" fill="none"/>
  <path d="M380 312 C 285 312, 285 312, 190 312" stroke="#2563eb" stroke-width="3" fill="none"/>

  <path d="M190 368 C 190 425, 190 425, 190 478" stroke="#2563eb" stroke-width="3" fill="none"/>

  <path d="M190 534 C 285 534, 285 534, 380 534" stroke="#2563eb" stroke-width="3" fill="none"/>
  <path d="M590 534 C 685 534, 685 534, 780 534" stroke="#2563eb" stroke-width="3" fill="none"/>

  <!-- CORREGIDA -->
  <path d="M980 590 C 980 646, 780 646, 590 700" stroke="#2563eb" stroke-width="3" fill="none"/>

</svg>

</section>

</body>
</html>
