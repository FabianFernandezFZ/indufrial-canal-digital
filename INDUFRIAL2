          <div class="text-2xl font-black tracking-tight text-slate-950 leading-tight">Acceso · validación · responsables</div>
          <div class="mt-3 text-sm font-bold text-slate-600 leading-relaxed">Información, áreas involucradas y responsables visibles.</div>
        </button>

        <button class="node-btn rounded-4xl p-5 text-left" onclick="openModal('m11')">
          <div class="flex items-start justify-between gap-3 mb-4">
            <div class="w-11 h-11 rounded-2xl bg-emerald-600 text-white flex items-center justify-center font-black">11</div>
            <div class="text-[10px] uppercase tracking-[0.24em] text-slate-500 font-extrabold">Salida</div>
