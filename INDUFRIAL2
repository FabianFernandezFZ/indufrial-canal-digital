            <span class="mini-pill px-3 py-2 rounded-full text-xs font-bold">Entrega</span>
            <span class="mini-pill px-3 py-2 rounded-full text-xs font-bold">Método</span>
            <span class="mini-pill px-3 py-2 rounded-full text-xs font-bold">Etapas</span>
          </div>
        </div>
        <div class="card rounded-3xl p-4">
