<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Indufrial | RESUMEN EJECUTIVO DE ALCANCE</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['Inter', 'sans-serif'],
          },
          colors: {
            brand: {
              50: '#f5f9ff',
              100: '#eaf3ff',
              200: '#d8e8ff',
              300: '#b9d5ff',
              400: '#7fb1ff',
              500: '#4f8df7',
              600: '#2563eb',
              700: '#1d4ed8',
              800: '#173ea8',
              900: '#0f2d74',
            }
          },
          boxShadow: {
            soft: '0 10px 30px rgba(15,23,42,0.06)',
            hover: '0 18px 40px rgba(37,99,235,0.10)',
          },
          borderRadius: {
            '4xl': '2rem'
          }
        }
      }
    }
  </script>
  <style>
    html { scroll-behavior: smooth; }
    body{
      font-family: 'Inter', sans-serif;
      background:
        radial-gradient(circle at top left, rgba(79,141,247,.08), transparent 24%),
        linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
      color:#0f172a;
      overflow-x:hidden;
    }

    .card{
      background: rgba(255,255,255,.92);
      border: 1px solid rgba(148,163,184,.18);
      box-shadow: 0 10px 30px rgba(15,23,42,.05);
      backdrop-filter: blur(10px);
      transition: all .25s ease;
    }

    .card:hover{
      transform: translateY(-2px);
      box-shadow: 0 18px 40px rgba(37,99,235,.10);
      border-color: rgba(37,99,235,.22);
    }

    .node-btn{
      position: relative;
      overflow: hidden;
      background:
        radial-gradient(circle at top right, rgba(79,141,247,.10), transparent 28%),
        linear-gradient(180deg, #ffffff 0%, #f9fbff 100%);
      border:1px solid rgba(148,163,184,.18);
      box-shadow: 0 10px 30px rgba(15,23,42,.05);
      transition: all .22s ease;
    }

    .node-btn:hover,
    .node-btn.active{
      transform: translateY(-2px);
      border-color: rgba(37,99,235,.28);
      box-shadow: 0 18px 40px rgba(37,99,235,.10);
    }

    .node-btn::after{
      content:"";
      position:absolute;
      inset:auto -20px -28px auto;
      width:110px;
      height:110px;
      border-radius:999px;
      background:radial-gradient(circle, rgba(37,99,235,.10), transparent 68%);
      pointer-events:none;
    }

    .flow-shell{
      position: relative;
    }

    .flow-line{
      position:absolute;
      inset:0;
      pointer-events:none;
      opacity:.28;
    }

    .mini-pill{
      background:#f4f8ff;
      border:1px solid #dbe9ff;
    }

    .modal-blur{
      backdrop-filter: blur(12px);
      background: rgba(15,23,42,.30);
    }

    .metric-value{
      font-variant-numeric: tabular-nums;
    }

    .glow-dot{
      box-shadow: 0 0 0 5px rgba(37,99,235,.08);
    }

    @media (max-width: 1024px){
      .flow-line{ display:none; }
    }
  </style>
</head>
<body class="p-4 md:p-6">

  <!-- Top -->
  <header class="max-w-7xl mx-auto mb-6">
    <div class="flex items-center justify-between gap-4">
      <div class="flex items-center gap-3 min-w-0">
        <div class="w-11 h-11 rounded-2xl bg-brand-600 text-white flex items-center justify-center font-black shadow-soft">I</div>
        <div class="min-w-0">
          <div class="text-[11px] uppercase tracking-[0.28em] text-slate-500 font-extrabold">Tablero Ejecutivo de Decisión</div>
          <div class="text-sm md:text-base font-black tracking-tight text-slate-950 truncate">Indufrial · Canal comercial digital</div>
        </div>
      </div>
      <div class="hidden md:flex items-center gap-2 text-[11px] uppercase tracking-[0.22em] font-extrabold text-brand-700">
        <span class="px-3 py-2 rounded-full mini-pill">Etapa inicial</span>
      </div>
    </div>
  </header>

  <!-- DIRECT ENTRY: starts with buttons -->
  <main class="max-w-7xl mx-auto space-y-6">

    <!-- Immediate map / buttons -->
    <section class="flow-shell card rounded-4xl p-4 md:p-6">
      <div class="mb-4 md:mb-5">
        <div class="text-[11px] uppercase tracking-[0.28em] text-brand-700 font-extrabold mb-2">RESUMEN VISUAL DEL ALCANCE</div>
        <h1 class="text-2xl md:text-4xl font-black tracking-tight text-slate-950 leading-tight">
          Arranque del canal digital
        </h1>
      </div>

      <!-- Zones -->
      <div class="grid grid-cols-2 xl:grid-cols-4 gap-3 md:gap-4 mb-5">
