<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Indufrial | Decision Board Premium</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;800&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    },
                    colors: {
                        'premium-gold': '#d4af37',
                        'premium-blue': '#00d4ff',
                        'premium-bg': '#05070a',
                    }
                }
            }
        }
    </script>
    <style>
        body { 
            background-color: #05070a; 
            color: #e2e8f0; 
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }
        .glass-panel {
            background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .glass-panel:hover {
            border-color: rgba(0, 212, 255, 0.3);
            background: rgba(15, 23, 42, 0.8);
            transform: translateY(-2px);
        }
        .modal-blur {
            backdrop-filter: blur(20px);
            background: rgba(2, 6, 23, 0.8);
        }
        .text-gradient {
            background: linear-gradient(90deg, #fff, #94a3b8);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .status-dot {
            width: 6px; height: 6px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 8px;
            box-shadow: 0 0 8px currentColor;
        }
    </style>
</head>
<body class="p-4 md:p-8">

    <!-- Top Navigation / Brand -->
    <nav class="max-w-6xl mx-auto flex justify-between items-center mb-12">
        <div class="flex items-center gap-4">
            <div class="h-10 w-[2px] bg-gradient-to-b from-premium-blue to-transparent"></div>
            <div>
                <h1 class="text-xl font-extrabold tracking-tighter text-white uppercase">Indufrial <span class="text-premium-blue">.</span></h1>
                <p class="text-[9px] font-mono text-slate-500 uppercase tracking-[0.4em]">Executive Decision Board</p>
            </div>
        </div>
        <div class="text-right">
            <p class="text-[10px] font-mono text-slate-400">ESTRATEGO_CORE / V.4.0</p>
            <p class="text-[9px] text-premium-blue font-bold uppercase tracking-widest">Ready for Deployment</p>
        </div>
    </nav>

    <!-- Main Grid -->
    <main class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        
        <!-- Question Block 1 -->
        <div class="glass-panel p-6 rounded-2xl cursor-pointer group" onclick="openModal('q1')">
            <span class="text-[10px] font-bold text-premium-blue/60 mb-2 block uppercase tracking-widest">Impacto Real</span>
            <h2 class="text-lg font-semibold text-white leading-tight mb-4">¿Qué problema real resuelve esto en Indufrial?</h2>
            <div class="flex items-center justify-between text-slate-500 group-hover:text-premium-blue transition-colors">
                <span class="text-[11px] font-mono italic">Ver Tesis Central</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
            </div>
        </div>

        <!-- Question Block 2 -->
        <div class="glass-panel p-6 rounded-2xl cursor-pointer group" onclick="openModal('q2')">
            <span class="text-[10px] font-bold text-premium-blue/60 mb-2 block uppercase tracking-widest">Urgencia</span>
            <h2 class="text-lg font-semibold text-white leading-tight mb-4">¿Por qué vale la pena hacerlo ahora mismo?</h2>
            <div class="flex items-center justify-between text-slate-500 group-hover:text-premium-blue transition-colors">
                <span class="text-[11px] font-mono italic">Opportunity Window</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
            </div>
        </div>

        <!-- Question Block 3 -->
        <div class="glass-panel p-6 rounded-2xl cursor-pointer group" onclick="openModal('q3')">
            <span class="text-[10px] font-bold text-premium-blue/60 mb-2 block uppercase tracking-widest">Metodología</span>
            <h2 class="text-lg font-semibold text-white leading-tight mb-4">¿Qué va a hacer en general y cómo lo va a hacer?</h2>
            <div class="flex items-center justify-between text-slate-500 group-hover:text-premium-blue transition-colors">
                <span class="text-[11px] font-mono italic">Workflow Strategy</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
            </div>
        </div>

        <!-- Question Block 4 -->
        <div class="glass-panel p-6 rounded-2xl cursor-pointer group" onclick="openModal('q4')">
            <span class="text-[10px] font-bold text-premium-blue/60 mb-2 block uppercase tracking-widest">Cronograma</span>
            <h2 class="text-lg font-semibold text-white leading-tight mb-4">¿Cuántas etapas tiene y cuánto tiempo toma?</h2>
            <div class="flex items-center justify-between text-slate-500 group-hover:text-premium-blue transition-colors">
                <span class="text-[11px] font-mono italic">Timeframe & Phases</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
            </div>
        </div>

        <!-- Question Block 5 -->
        <div class="glass-panel p-6 rounded-2xl cursor-pointer group" onclick="openModal('q5')">
            <span class="text-[10px] font-bold text-premium-blue/60 mb-2 block uppercase tracking-widest">Riesgos</span>
            <h2 class="text-lg font-semibold text-white leading-tight mb-4">¿Qué riesgos se reducen al arrancar así?</h2>
            <div class="flex items-center justify-between text-slate-500 group-hover:text-premium-blue transition-colors">
                <span class="text-[11px] font-mono italic">Risk Mitigation</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
            </div>
        </div>

        <!-- Question Block 6 -->
        <div class="glass-panel p-6 rounded-2xl cursor-pointer group border-premium-blue/20 bg-premium-blue/5" onclick="openModal('q6')">
            <span class="text-[10px] font-bold text-premium-blue mb-2 block uppercase tracking-widest">Final Output</span>
            <h2 class="text-lg font-semibold text-white leading-tight mb-4">¿Qué me va a entregar exactamente al final?</h2>
            <div class="flex items-center justify-between text-premium-blue transition-colors">
                <span class="text-[11px] font-mono italic font-bold tracking-widest uppercase">Resultados Tangibles</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 8l4 4m0 0l-4 4m4-4H3" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
            </div>
        </div>

    </main>

    <!-- Bottom Metrics -->
    <section class="max-w-6xl mx-auto mt-12 grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="p-4 border-l border-white/10">
            <p class="text-[9px] uppercase tracking-widest text-slate-500">Avance Real</p>
            <p class="text-xl font-bold text-white">Semana 2</p>
        </div>
        <div class="p-4 border-l border-white/10">
            <p class="text-[9px] uppercase tracking-widest text-slate-500">Dependencia</p>
            <p class="text-xl font-bold text-white">Data Interna</p>
        </div>
        <div class="p-4 border-l border-white/10">
            <p class="text-[9px] uppercase tracking-widest text-slate-500">Enfoque</p>
            <p class="text-xl font-bold text-premium-blue uppercase italic">Ejecución</p>
        </div>
        <div class="p-4 border-l border-white/10">
            <p class="text-[9px] uppercase tracking-widest text-slate-500">Status</p>
            <p class="text-xl font-bold text-green-500 uppercase italic">READY</p>
        </div>
    </section>

    <!-- Modales (Arquitectura de Preguntas) -->

    <!-- Q1 -->
    <div id="q1" class="modal fixed inset-0 z-[2000] hidden items-center justify-center p-4 modal-blur" onclick="closeModal('q1')">
        <div class="bg-slate-900 w-full max-w-lg rounded-3xl p-8 border border-white/10" onclick="event.stopPropagation()">
            <h3 class="text-premium-blue font-mono text-xs uppercase tracking-[0.3em] mb-4">Misión Estratégica</h3>
            <p class="text-xl text-white font-semibold leading-relaxed mb-6">Resuelve la ceguera operativa.</p>
            <p class="text-slate-400 text-sm leading-relaxed">
                Elimina el crecimiento desordenado. Evita que Indufrial agote recursos en ventas que la operación no puede procesar, asegurando que cada nuevo cliente sea rentable y escalable.
            </p>
            <button onclick="closeModal('q1')" class="mt-8 w-full py-4 bg-white/5 hover:bg-white/10 text-white rounded-xl font-bold text-xs uppercase tracking-widest transition-all">Cerrar Dashboard</button>
        </div>
    </div>

    <!-- Q2 -->
    <div id="q2" class="modal fixed inset-0 z-[2000] hidden items-center justify-center p-4 modal-blur" onclick="closeModal('q2')">
        <div class="bg-slate-900 w-full max-w-lg rounded-3xl p-8 border border-white/10" onclick="event.stopPropagation()">
            <h3 class="text-premium-blue font-mono text-xs uppercase tracking-[0.3em] mb-4">Urgencia</h3>
            <p class="text-xl text-white font-semibold leading-relaxed mb-6">Escalar sobre el caos es mortal.</p>
            <p class="text-slate-400 text-sm leading-relaxed">
                Hacerlo ahora permite capturar el mercado con una eficiencia que su competencia no tiene. Cada día de retraso es presupuesto perdido en fricciones operativas invisibles.
            </p>
            <button onclick="closeModal('q2')" class="mt-8 w-full py-4 bg-white/5 hover:bg-white/10 text-white rounded-xl font-bold text-xs uppercase tracking-widest transition-all">Cerrar Dashboard</button>
        </div>
    </div>

    <!-- Q3 -->
    <div id="q3" class="modal fixed inset-0 z-[2000] hidden items-center justify-center p-4 modal-blur" onclick="closeModal('q3')">
        <div class="bg-slate-900 w-full max-w-lg rounded-3xl p-8 border border-white/10" onclick="event.stopPropagation()">
            <h3 class="text-premium-blue font-mono text-xs uppercase tracking-[0.3em] mb-4">Metodología</h3>
            <p class="text-xl text-white font-semibold leading-relaxed mb-4">Auditoría, Estructuración y Activación.</p>
            <div class="space-y-4 text-slate-400 text-sm">
                <p>Analizamos data real, diseñamos protocolos digitales de respuesta rápida e implementamos el nuevo flujo directamente en los equipos. No solo observamos: <b class="text-white">reconfiguramos.</b></p>
                <div class="p-4 bg-white/5 rounded-xl border-l-4 border-premium-blue">
                    <p class="text-xs italic">¿Qué necesita de Indufrial? Acceso total a data, validación de líderes y apertura al cambio operativo.</p>
                </div>
            </div>
            <button onclick="closeModal('q3')" class="mt-8 w-full py-4 bg-white/5 hover:bg-white/10 text-white rounded-xl font-bold text-xs uppercase tracking-widest transition-all">Cerrar Dashboard</button>
        </div>
    </div>

    <!-- Q4 -->
    <div id="q4" class="modal fixed inset-0 z-[2000] hidden items-center justify-center p-4 modal-blur" onclick="closeModal('q4')">
        <div class="bg-slate-900 w-full max-w-lg rounded-3xl p-8 border border-white/10" onclick="event.stopPropagation()">
            <h3 class="text-premium-blue font-mono text-xs uppercase tracking-[0.3em] mb-4">Fases y Tiempos</h3>
            <div class="grid grid-cols-2 gap-4 mb-6">
                <div class="bg-white/5 p-4 rounded-xl">
                    <p class="text-[9px] text-slate-500 uppercase">Duración</p>
                    <p class="text-lg font-bold text-white">4 - 8 Semanas</p>
                </div>
                <div class="bg-white/5 p-4 rounded-xl">
                    <p class="text-[9px] text-slate-500 uppercase">Avance Real</p>
                    <p class="text-lg font-bold text-premium-blue">Semana 2</p>
                </div>
            </div>
            <ul class="space-y-3 text-slate-400 text-xs">
                <li class="flex items-center gap-3"><span class="status-dot bg-premium-blue"></span> <b>Fase 1:</b> Auditoría & Hallazgos Críticos.</li>
                <li class="flex items-center gap-3"><span class="status-dot bg-slate-600"></span> <b>Fase 2:</b> Arquitectura del Modelo (Protocolos).</li>
                <li class="flex items-center gap-3"><span class="status-dot bg-slate-600"></span> <b>Fase 3:</b> Desbloqueo de Fricciones.</li>
                <li class="flex items-center gap-3"><span class="status-dot bg-slate-600"></span> <b>Fase 4:</b> Activación del Frente Operativo.</li>
            </ul>
            <button onclick="closeModal('q4')" class="mt-8 w-full py-4 bg-white/5 hover:bg-white/10 text-white rounded-xl font-bold text-xs uppercase tracking-widest transition-all">Cerrar Dashboard</button>
        </div>
    </div>

    <!-- Q5 -->
    <div id="q5" class="modal fixed inset-0 z-[2000] hidden items-center justify-center p-4 modal-blur" onclick="closeModal('q5')">
        <div class="bg-slate-900 w-full max-w-lg rounded-3xl p-8 border border-white/10" onclick="event.stopPropagation()">
            <h3 class="text-premium-blue font-mono text-xs uppercase tracking-[0.3em] mb-4">Mitigación de Riesgos</h3>
            <p class="text-xl text-white font-semibold leading-relaxed mb-6">Cura la insostenibilidad financiera.</p>
            <p class="text-slate-400 text-sm leading-relaxed mb-4">
                Reducimos el riesgo de quemar presupuesto en marketing sin capacidad de entrega. Evitamos quejas, devoluciones y la erosión de la marca por mala gestión de expectativas.
            </p>
            <div class="bg-red-500/10 border border-red-500/20 p-3 rounded-xl text-[10px] text-red-400 text-center">
                RIESGO REDUCIDO: DESPLOME POR CRECIMIENTO ACELERADO.
            </div>
            <button onclick="closeModal('q5')" class="mt-8 w-full py-4 bg-white/5 hover:bg-white/10 text-white rounded-xl font-bold text-xs uppercase tracking-widest transition-all">Cerrar Dashboard</button>
        </div>
    </div>

    <!-- Q6 -->
    <div id="q6" class="modal fixed inset-0 z-[2000] hidden items-center justify-center p-4 modal-blur" onclick="closeModal('q6')">
        <div class="bg-slate-900 w-full max-w-lg rounded-3xl p-8 border border-white/10 shadow-[0_0_50px_rgba(0,212,255,0.15)]" onclick="event.stopPropagation()">
            <h3 class="text-premium-blue font-mono text-xs uppercase tracking-[0.3em] mb-4">Entregables de Valor</h3>
            <p class="text-xl text-white font-semibold leading-relaxed mb-6">No es un plan, es ejecución real.</p>
            <div class="grid grid-cols-1 gap-3">
                <div class="flex items-center justify-between p-4 bg-white/5 rounded-2xl border border-white/10">
                    <span class="text-xs text-slate-300">Sistema de Gobierno Digital</span>
                    <span class="text-[9px] font-mono text-premium-blue">CORE</span>
                </div>
                <div class="flex items-center justify-between p-4 bg-white/5 rounded-2xl border border-white/10">
                    <span class="text-xs text-slate-300">Protocolos de Respuesta Rápida</span>
                    <span class="text-[9px] font-mono text-premium-blue">SOP</span>
                </div>
                <div class="flex items-center justify-between p-4 bg-white/5 rounded-2xl border border-white/10">
                    <span class="text-xs text-slate-300">Primer Frente Operativo Activado</span>
                    <span class="text-[9px] font-mono text-premium-blue">LIVE</span>
                </div>
            </div>
            <button onclick="closeModal('q6')" class="mt-8 w-full py-4 bg-premium-blue/10 hover:bg-premium-blue/20 text-premium-blue border border-premium-blue/30 rounded-xl font-bold text-xs uppercase tracking-widest transition-all">Finalizar Consulta</button>
        </div>
    </div>

    <script>
        function openModal(id) {
            const modal = document.getElementById(id);
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.style.overflow = 'hidden';
        }
        function closeModal(id) {
            const modal = document.getElementById(id);
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            document.body.style.overflow = 'auto';
        }
    </script>
</body>
</html>
