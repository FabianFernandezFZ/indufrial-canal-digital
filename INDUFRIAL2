          <div class="flex flex-wrap gap-2">
            <span class="mini-pill px-3 py-2 rounded-full text-xs font-bold">Tiempo</span>
            <span class="mini-pill px-3 py-2 rounded-full text-xs font-bold">Minivictorias</span>
            <span class="mini-pill px-3 py-2 rounded-full text-xs font-bold">Avance</span>
          </div>
        </div>
        <div class="card rounded-3xl p-4">
          <div class="text-[10px] uppercase tracking-[0.26em] text-brand-700 font-extrabold mb-3">Arranque</div>
          <div class="flex flex-wrap gap-2">
            <span class="mini-pill px-3 py-2 rounded-full text-xs font-bold">Indufrial</span>
            <span class="mini-pill px-3 py-2 rounded-full text-xs font-bold">Salida</span>
          </div>
        </div>
      </div>

      <!-- Flow SVG -->
      <svg class="flow-line" viewBox="0 0 1200 760" preserveAspectRatio="none" aria-hidden="true">
        <path d="M190 92 C 285 92, 285 92, 380 92" stroke="#2563eb" stroke-width="3" fill="none"/>
        <path d="M590 92 C 685 92, 685 92, 780 92" stroke="#2563eb" stroke-width="3" fill="none"/>
        <path d="M980 146 C 980 204, 980 204, 980 258" stroke="#2563eb" stroke-width="3" fill="none"/>
